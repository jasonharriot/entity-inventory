<!DOCTYPE html>

<html>
	<head>
		<link rel="stylesheet" href="style/style.css" />

		<meta name="viewport" content="width=device-width,initial-scale=1.0">

		<title><%= config.get('site_name') %></title>
	</head>
	<body>
		<div id="container">
			<div id="header" class="section">
				<div>
					<h1><%= config.get("site_name"); %></h1>
				</div>
				<div class="scanDiv">
					<img src="img/scanner-bw.png" width="100px">
					<p>Scan a tag at any time to view its details.</p>
				</div>
			</div>

			<div id="contentContainer">
				<div class="section">
					<h2>Tools</h2>
					<p><a href="search.html">Search</a>&mdash;<i>Shortcut key: S</i></p>
					<p><a href="card-list.html">View all cards</a>&mdash;<i>Shortcut key: L</i></p>
					<p><a href="go-to-card.html">Go to ID number</a>&mdash;<i>Shortcut key: G</i></p>
					<p><a href="bulk-landing.html">Bulk operations</a></p>
					<p><a href="issue.html">Print new labels</a></p>
				</div>

				<div class="section">
					<h2>
						Info
					</h2>
					<div>
						<p>
							<a href="https://github.com/jasonharriot/entity-inventory">
								Entity Inventory&mdash;GitHub
							</a>
							<% if(authenticatedUser){%>
							<p><a href="user">User profile</a></p>
							<%} else{%>
							<p><a href="login">Log in</a></p>
							<p><a href="register">Register new account</a></p>
							<%}%>
							<p><a href="debug.html">Debugging tools</a></p>
						</p>
					</div>
					
				</div>
			</div>

			<div id="footer" class="section">
				<div>
					<p><%- config.get('copyright_text') %></p>
				</div>
			</div>
		</div>

		<script type="text/javascript" src="js/page-scan-watch.js"></script>
		<script type="text/javascript" src="js/page-scan-default.js"></script>
	</body>
</html>
